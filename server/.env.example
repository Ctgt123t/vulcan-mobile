# Anthropic API key. Get one at https://console.anthropic.com/
# In production (Railway), set this in the project's Variables tab — not in a .env file.
ANTHROPIC_API_KEY=

# Port the backend listens on. Local dev only.
# Railway injects its own PORT at runtime; the server reads process.env.PORT and
# will use that automatically. Do NOT set PORT in the Railway dashboard.
PORT=3000
