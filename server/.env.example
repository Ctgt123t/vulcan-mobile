# Anthropic API key. Get one at https://console.anthropic.com/
# In production (Railway), set this in the project's Variables tab — not in a .env file.
ANTHROPIC_API_KEY=

# Vehicle Finder API key (https://vehicle-finder.com). Optional. Provides oil
# specs, torque specs, and maintenance schedules. If unset, that provider is
# skipped and spec lookups for those categories fall through to Claude.
VEHICLE_FINDER_API_KEY=

# Open Labor Project API key (https://openlaborproject.com/developers).
# Optional. Hobbyist tier (50 req/day, manual review). Once docs are confirmed,
# flip ENABLED=true in server/specProviders/openLabor.js and this key will be
# used for fluid/battery/labor spec lookups.
OPEN_LABOR_API_KEY=

# Port the backend listens on. Local dev only.
# Railway injects its own PORT at runtime; the server reads process.env.PORT and
# will use that automatically. Do NOT set PORT in the Railway dashboard.
PORT=3000
