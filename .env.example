# Backend URL. The app POSTs to ${EXPO_PUBLIC_API_BASE_URL}/api/diagnose.
# See DEV_SETUP.md for the full workflow.
#
# Local dev via ngrok:   https://<your-subdomain>.ngrok-free.dev
# Production (Railway):  https://<your-service>.up.railway.app
#
# No trailing slash. EXPO_PUBLIC_* vars are baked in at Expo start time —
# restart with `npx expo start -c` after changing this.
EXPO_PUBLIC_API_BASE_URL=

# Verbose OBD2 logging. Off by default. Set to 1 to enable per-tick
# polling logs, transport TX/RX, scan-ingestion events, and per-handshake-
# command exchanges. Restart Expo with `npx expo start -c` after changing.
# Preview / production builds never set this, so production binaries stay
# silent regardless of what's in your local .env. See lib/debug.ts.
EXPO_PUBLIC_DEBUG_OBD2=0
