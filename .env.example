# Backend URL. The app POSTs to ${EXPO_PUBLIC_API_BASE_URL}/api/diagnose.
# See DEV_SETUP.md for the full workflow.
#
# Local dev via ngrok:   https://<your-subdomain>.ngrok-free.dev
# Production (Railway):  https://<your-service>.up.railway.app
#
# No trailing slash. EXPO_PUBLIC_* vars are baked in at Expo start time —
# restart with `npx expo start -c` after changing this.
EXPO_PUBLIC_API_BASE_URL=
